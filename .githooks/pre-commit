#!/bin/bash
# pre-commit hook: запрещает коммит секретов и runtime-файлов.
# Адаптирован из pit-fleet/.githooks/pre-commit (обкатан в бою).
# Активация: git config core.hooksPath .githooks

set -euo pipefail

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# 1. Запрещённые пути: env, токены, cookies, сессии, базы, runtime-state.
FORBIDDEN_PATTERN='(^|/)([^/]+\.env|\.env)$|token.*\.json|TK_cookies|\.session|\.pickle$|\.db$|(^|/)pending\.json$|stats_history\.json|pub_calendar\.json'
BAD=$(echo "$STAGED_FILES" | grep -E "$FORBIDDEN_PATTERN" | grep -vE '\.env\.(example|template)$' || true)
if [ -n "$BAD" ]; then
  echo "[pre-commit] ERROR: попытка закоммитить секрет/runtime-файлы:"
  echo "$BAD"
  echo "Hint: секреты живут на сервере, в git только *.example/*.template."
  exit 1
fi
unset BAD FORBIDDEN_PATTERN

# 2. Secret scan по ЗНАЧЕНИЯМ: Notion / Google OAuth+refresh / Anthropic /
#    Groq / Telegram bot token / Gemini / Meta long-lived (EAA…) / JWT-пара.
SECRET_PATTERNS='(ntn_[a-zA-Z0-9_]{20,}|secret_[a-zA-Z0-9]{30,}|GOCSPX-[a-zA-Z0-9_-]{20,}|1//0[a-zA-Z0-9_-]{30,}|sk-ant-[a-zA-Z0-9_-]{20,}|gsk_[a-zA-Z0-9]{30,}|[0-9]{8,}:[A-Za-z0-9_-]{30,}|AIza[0-9A-Za-z_-]{30,}|EAA[A-Za-z0-9]{50,}|eyJ[A-Za-z0-9_-]{15,}\.eyJ)'

if git diff --cached -U0 | grep -E "^[+]" | grep -vE '^\+\+\+' | grep -qE "$SECRET_PATTERNS"; then
  echo "[pre-commit] ERROR: похоже на секрет в staged-контенте:"
  git diff --cached -U0 | grep -E "^[+]" | grep -vE '^\+\+\+' | grep -nE "$SECRET_PATTERNS" | head -5 || true
  echo "Hint: real secret → git restore --staged <file>; false positive → уточни regex."
  exit 1
fi

echo "[pre-commit] OK"
