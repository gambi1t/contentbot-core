{
  "version": 1,
  "_about": "Единый style contract для всех HyperFrames-сцен Максима. Передаётся ВСЕМ параллельным subagent'ам одинаковым (вместо done_scenes cross-talk). Создан по ревью ChatGPT 4 июня 2026 как Phase 1 Step 2 production-плана. См. docs/hyperframes_production_plan_review_2026-06-04.md.",
  "palette": {
    "bg_primary": "#0A0A0A",
    "bg_secondary": "#111111",
    "accent": "#FF5722",
    "text_primary": "#FFFFFF",
    "text_muted": "#BBBBBB"
  },
  "typography": {
    "primary_family": "Inter Tight",
    "body_family": "Inter",
    "weights": [500, 600, 800],
    "hero_min_px": 84,
    "hero_max_px": 92,
    "body_min_px": 24,
    "body_max_px": 26,
    "kicker_min_px": 20,
    "kicker_max_px": 22,
    "caption_min_px": 20,
    "caption_max_px": 26
  },
  "spacing": {
    "safe_area": {"x": [40, 1040], "y": [480, 1440]},
    "gap_min_px": 48,
    "padding_px": 40
  },
  "frame": {
    "width": 1080,
    "height": 1920,
    "duration_s": 5
  },
  "forbidden_labels": [
    "SCENE 01", "SCENE 02", "SCENE 03", "SCENE 04", "SCENE 05", "SCENE 06",
    "SCENE / 01", "SCENE / 02", "SCENE / 03", "SCENE / 04", "SCENE / 05", "SCENE / 06",
    "FINAL CTA", "FINAL_CTA",
    "DEBUG", "TODO:", "FIXME:", "XXX:"
  ],
  "forbidden_patterns_regex": [
    "\\bSCENE\\s*[/]?\\s*0\\d\\b",
    "\\bFINAL\\s+CTA\\b",
    "\\bscene\\s+\\d+\\s+of\\s+\\d+\\b"
  ]
}
